{
  "name": "granaevo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.4.0",
  "scripts": {
    "dev": "vite",
    "fa:subset": "node scripts/build-fa-subset.mjs",
    "fonts:subset": "node scripts/build-fonts-subset.mjs",
    "lighttheme:build": "node scripts/build-light-theme.mjs",
    "prebuild": "node scripts/check-refs.mjs && node scripts/build-fa-subset.mjs && node scripts/build-fonts-subset.mjs && node scripts/build-light-theme.mjs",
    "build": "vite build",
    "postbuild": "node scripts/check-bundle-size.mjs",
    "preview": "vite preview",
    "deadcode": "knip --no-progress",
    "coverage:summary": "node scripts/coverage-summary.mjs",
    "images:optimize": "node scripts/optimize-images.mjs",
    "test": "node --test tests/security/",
    "test:security": "node --test tests/security/security.test.js",
    "test:unit": "node --test \"tests/unit/**/*.test.js\"",
    "check:refs": "node scripts/check-refs.mjs",
    "lh": "lhci autorun --config=lighthouserc.cjs"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@sentry/browser": "^10.55.0",
    "@supabase/supabase-js": "2.104.1",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@fontsource/syne": "^5.2.7",
    "@lhci/cli": "^0.14.0",
    "esbuild": "^0.28.0",
    "knip": "^6.17.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.35.1",
    "subset-font": "^2.5.0",
    "terser": "^5.31.0",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.3.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
