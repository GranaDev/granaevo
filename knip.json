{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "*.html",
    "src/scripts/pages/*.js",
    "public/theme-init.js",
    "public/pwa-init.js",
    "public/sw-push-handler.js",
    "public/scripts/modules/graficos.js",
    "public/scripts/modules/recaptcha-init.js",
    "public/scripts/vendor/chart.umd.min.js",
    "scripts/*.mjs"
  ],
  "project": [
    "src/**/*.js",
    "public/scripts/**/*.js",
    "public/*.js",
    "scripts/**/*.mjs"
  ],
  "ignore": [
    "supabase/**"
  ],
  "ignoreBinaries": ["vercel", "supabase"],
  "ignoreDependencies": [
    "@fortawesome/fontawesome-free",
    "@fontsource/dm-sans",
    "@fontsource/inter",
    "@fontsource/outfit",
    "@fontsource/syne"
  ]
}
